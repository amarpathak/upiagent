# ─── Gmail OAuth (required for payment verification) ─────────────
# Run `npx upiagent setup` to generate these automatically
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# ─── LLM Provider (set at least one) ─────────────────────────────
# The library auto-detects the provider from whichever key is set.
# If multiple are set, priority: OpenAI > Anthropic > Gemini > OpenRouter
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
OPENROUTER_API_KEY=

# ─── OpenAI-Compatible (optional) ────────────────────────────────
# For self-hosted models (vLLM, Ollama, TGI)
# OPENAI_COMPATIBLE_BASE_URL=http://localhost:8000/v1
# OPENAI_COMPATIBLE_API_KEY=

# ─── PostgreSQL Dedup (optional) ─────────────────────────────────
# Only needed if using PostgresDedupStore instead of in-memory dedup.
# Without this, InMemoryDedupStore is used (resets on restart).
# DATABASE_URL=postgresql://user:pass@localhost:5432/upiagent

# ─── Webhook (optional) ──────────────────────────────────────────
# WEBHOOK_URL=https://yourapp.com/api/webhooks/payment
# WEBHOOK_SECRET=your-webhook-signing-secret

# ─── Encryption (optional) ───────────────────────────────────────
# For encrypting stored credentials. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ENCRYPTION_KEY=
