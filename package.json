{
  "name": "upiagent",
  "version": "0.1.0",
  "description": "UPI payment gateway — QR generation, Gmail verification, LLM parsing. No Razorpay needed.",
  "homepage": "https://github.com/AmarPathak/upiagent",
  "repository": {
    "type": "git",
    "url": "https://github.com/AmarPathak/upiagent.git"
  },
  "bugs": {
    "url": "https://github.com/AmarPathak/upiagent/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "upiagent": "./dist/setup/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ && tsc --noEmit",
    "publish:dry": "pnpm publish --dry-run --no-git-checks",
    "setup": "node dist/setup/cli.js"
  },
  "keywords": [
    "upi",
    "payment",
    "verification",
    "gmail",
    "llm",
    "langchain",
    "india",
    "fintech"
  ],
  "author": "Amar Pathak",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@types/qrcode": "^1.5.6",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.26",
    "@langchain/core": "^1.1.38",
    "@langchain/google-genai": "^2.1.26",
    "@langchain/openai": "^1.4.1",
    "googleapis": "^171.4.0",
    "qrcode": "^1.5.4",
    "zod": "^4.3.6"
  }
}
